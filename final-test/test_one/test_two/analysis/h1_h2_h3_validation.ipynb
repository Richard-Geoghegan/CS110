import json

import matplotlib.pyplot as plt
import numpy as np
import pandas as pd
from scipy import stats

# Load Phase 1 baseline & Phase 2/3 triggered metrics
with open("../baseline_metrics.json") as f: baseline = json.load(f)
# Assume collected_data.csv has columns: run_id, phase, p99_ms, cpu_pct, cache_misses, latency_ms
df = pd.read_csv("collected_data.csv")

# H1 Validation: ≤1.0% CPU overhead, ≤2% P99 shift
h1_baseline_cpu = baseline["cgroup_metrics"]["app-service"]["cpu"]
h1_trigger_cpu = df[df.phase=="baseline"]["cpu_pct"].mean()
h1_overhead = abs(h1_trigger_cpu - float(h1_baseline_cpu.strip('%')))
h1_pass = h1_overhead <= 1.0 and (df[df.phase=="baseline"]["p99_ms"].mean() - baseline["p99_ms"]) <= 2.0
print(f"H1 PASS: {h1_pass} (Overhead: {h1_overhead:.2f}%)")

# H2 Validation: TP rate ≥90%, peak overhead ≤2.5%
triggered = df[df.phase=="triggered"]
h2_overhead = triggered["cpu_pct"].mean()
h2_tp = (triggered["p99_ms"] > 500).mean()
print(f"H2 PASS: {h2_tp >= 0.9 and h2_overhead <= 2.5} (TP: {h2_tp:.2f}, Overhead: {h2_overhead:.2f}%)")

# H3 Validation: Pearson/Spearman ≥0.85 between cache_misses & latency
pearson, _ = stats.pearsonr(triggered["cache_misses"], triggered["latency_ms"])
spearman, _ = stats.spearmanr(triggered["cache_misses"], triggered["latency_ms"])
print(f"H3 Pearson: {pearson:.3f} | Spearman: {spearman:.3f} | PASS: {pearson >= 0.85}")

plt.scatter(triggered["cache_misses"], triggered["latency_ms"])
plt.xlabel("Cache Misses"); plt.ylabel("Request Latency (ms)")
plt.show()
